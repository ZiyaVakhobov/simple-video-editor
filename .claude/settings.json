{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(git init*)",
      "Bash(git add *)",
      "Bash(git status*)",
      "Bash(git commit *)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(tsc*)",
      "Bash(vite*)",
      "Bash(ffmpeg *)",
      "Bash(ffprobe *)",
      "Bash(curl *)",
      "Bash(which *)",
      "Bash(env*)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(lsof *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(sudo *)"
    ]
  }
}
